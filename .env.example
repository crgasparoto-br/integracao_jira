# Jira automation
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-atlassian-api-token
JIRA_PROJECT_KEY=AP

# Optional overrides
# The CLI auto-detects issue types from the selected project. Use these only if you
# want to force a specific mapping.
JIRA_DEFAULT_ISSUE_TYPE=Task
JIRA_EPIC_ISSUE_TYPE=Epic
JIRA_SUBTASK_ISSUE_TYPE=Subtask
JIRA_DEFAULT_LABELS=agendaprofi,planejamento

# Optional: company-managed projects may require the Epic Name custom field.
# Example: JIRA_EPIC_NAME_FIELD=customfield_10011
# JIRA_EPIC_NAME_FIELD=
